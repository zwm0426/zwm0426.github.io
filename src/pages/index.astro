---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero';
import About from '../components/About';
import { SectionHeading } from '../components/About';
import { getCollection } from 'astro:content';
import { ChevronRight } from 'lucide-react';

const newsEntries = await getCollection('news');
const sortedNews = newsEntries.sort((a, b) => (a.data.order || 99) - (b.data.order || 99)).slice(0, 3);
---

<BaseLayout title="Home">
  <Hero client:load />
  <About client:visible />
  
  <!-- News Preview Section -->
  <section id="news" class="py-24 bg-zinc-50 px-6 border-y border-zinc-100">
    <div class="max-w-6xl mx-auto">
      <div class="flex justify-between items-end mb-12">
        <SectionHeading client:visible subtitle="Stay updated with my latest academic and professional milestones.">
          Recent Updates
        </SectionHeading>
        <a href="/news" class="mb-12 text-sm font-bold text-zinc-900 hover:gap-2 transition-all flex items-center">
          View all news <ChevronRight size={16} className="ml-1" />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {sortedNews.map((item) => (
          <div
            class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm hover:shadow-xl transition-all duration-300 group"
          >
            <div class="flex justify-between items-start mb-6">
              <span class="text-xs font-bold text-zinc-400 uppercase tracking-widest">{item.data.date}</span>
              {item.data.tag && <span class="px-2 py-1 rounded-md bg-zinc-50 text-zinc-500 text-[10px] font-bold uppercase">{item.data.tag}</span>}
            </div>
            <h3 class="text-xl font-bold mb-3 group-hover:text-zinc-600 transition-colors">{item.data.title}</h3>
            <p class="text-zinc-500 text-sm leading-relaxed mb-6">
              {item.body.substring(0, 150)}...
            </p>
            <a href="/news" class="inline-flex items-center text-sm font-bold text-zinc-900 hover:gap-2 transition-all">
              Read more <ChevronRight size={16} className="ml-1" />
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

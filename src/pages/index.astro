---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero';
import About from '../components/About';
import { SectionHeading } from '../components/About';
import { getCollection } from 'astro:content';
import { ChevronRight } from 'lucide-react';
import profile from '../data/profile.json';
import links from '../data/links.json';
import site from '../data/site.json';

const newsEntries = await getCollection('news');
const sortedNews = newsEntries
  .filter((item) => !item.data.draft && item.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const formatNewsDate = (date: Date) => new Intl.DateTimeFormat('en', {
  month: 'short',
  year: 'numeric',
}).format(date);

const newsHref = (id: string) => `/news/${id.replace(/\.mdx?$/, '').replace(/\/index$/, '')}/`;
---

<BaseLayout title="Home" description={site.siteDescription}>
  <Hero client:load profile={profile} links={links} />
  <About client:visible profile={profile} />
  
  <!-- News Preview Section -->
  <section id="news" class="py-24 bg-zinc-50 px-6 border-y border-zinc-100">
    <div class="max-w-6xl mx-auto">
      <div class="flex justify-between items-end mb-12">
        <SectionHeading client:visible subtitle="Selected updates from my research, teaching, and professional work.">
          Recent Updates
        </SectionHeading>
        <a href="/news" class="mb-12 text-sm font-bold text-zinc-900 hover:gap-2 transition-all flex items-center">
          View all news <ChevronRight size={16} className="ml-1" />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {sortedNews.map((item) => (
          <div
            class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm hover:shadow-xl transition-all duration-300 group"
          >
            <div class="flex justify-between items-start mb-6">
              <span class="text-xs font-bold text-zinc-400 uppercase tracking-widest">{formatNewsDate(item.data.date)}</span>
              {(item.data.tag || item.data.tags[0]) && <span class="px-2 py-1 rounded-md bg-zinc-50 text-zinc-500 text-[10px] font-bold uppercase">{item.data.tag ?? item.data.tags[0]}</span>}
            </div>
            <h3 class="text-xl font-bold mb-3 group-hover:text-zinc-600 transition-colors">{item.data.title}</h3>
            <p class="text-zinc-500 text-sm leading-relaxed mb-6">
              {item.data.summary ?? `${item.body.substring(0, 150)}...`}
            </p>
            <a href={newsHref(item.id)} class="inline-flex items-center text-sm font-bold text-zinc-900 hover:gap-2 transition-all">
              Read more <ChevronRight size={16} className="ml-1" />
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

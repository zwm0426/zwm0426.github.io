---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ArrowLeft } from 'lucide-react';

const newsEntries = await getCollection('news');
const sortedNews = newsEntries.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
---

<BaseLayout title="News" description="A complete timeline of my professional journey and updates.">
  <div class="pt-32 pb-24 px-6 min-h-screen bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <a href="/" class="inline-flex items-center text-sm font-medium text-zinc-500 hover:text-zinc-900 transition-colors mb-8 group">
          <ArrowLeft size={16} className="mr-2 group-hover:-translate-x-1 transition-transform" /> Back to Home
        </a>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 mb-6">News</h1>
        <p class="text-xl text-zinc-500 max-w-3xl">A complete timeline of my professional journey and updates.</p>
        <div class="h-1 bg-zinc-900 w-20 mt-8" />
      </div>

      <div class="space-y-12">
        {sortedNews.map((item) => (
          <div class="flex flex-col md:flex-row gap-8 md:gap-16 items-start border-b border-zinc-100 pb-12">
            <div class="md:w-32 flex-shrink-0">
              <span class="text-sm font-bold text-zinc-400 uppercase tracking-widest">{item.data.date}</span>
              <div class="mt-2">
                {item.data.tag && <span class="px-2 py-1 rounded-md bg-zinc-100 text-zinc-500 text-[10px] font-bold uppercase">{item.data.tag}</span>}
              </div>
            </div>
            <div class="flex-grow">
              <h3 class="text-2xl font-bold mb-4">{item.data.title}</h3>
              <p class="text-zinc-600 leading-relaxed text-lg">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

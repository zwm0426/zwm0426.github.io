---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ArrowLeft, ChevronRight } from 'lucide-react';

const newsEntries = await getCollection('news');
const sortedNews = newsEntries
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatNewsDate = (date: Date) => new Intl.DateTimeFormat('en', {
  month: 'short',
  year: 'numeric',
}).format(date);

const newsHref = (id: string) => `/news/${id.replace(/\.mdx?$/, '').replace(/\/index$/, '')}/`;
---

<BaseLayout title="News" description="A complete timeline of my professional journey and updates.">
  <div class="pt-32 pb-24 px-6 min-h-screen bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <a href="/" class="inline-flex items-center text-sm font-medium text-zinc-500 hover:text-zinc-900 transition-colors mb-8 group">
          <ArrowLeft size={16} className="mr-2 group-hover:-translate-x-1 transition-transform" /> Back to Home
        </a>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 mb-6">News</h1>
        <p class="text-xl text-zinc-500 max-w-3xl">A complete timeline of my professional journey and updates.</p>
        <div class="h-1 bg-zinc-900 w-20 mt-8" />
      </div>

      <div class="space-y-12">
        {sortedNews.map((item) => (
          <div class="flex flex-col md:flex-row gap-8 md:gap-16 items-start border-b border-zinc-100 pb-12">
            <div class="md:w-32 flex-shrink-0">
              <span class="text-sm font-bold text-zinc-400 uppercase tracking-widest">{formatNewsDate(item.data.date)}</span>
              <div class="mt-2">
                {(item.data.tag || item.data.tags[0]) && <span class="px-2 py-1 rounded-md bg-zinc-100 text-zinc-500 text-[10px] font-bold uppercase">{item.data.tag ?? item.data.tags[0]}</span>}
              </div>
            </div>
            <div class="flex-grow">
              <a href={newsHref(item.id)} class="group inline-block">
                <h3 class="text-2xl font-bold mb-4 group-hover:text-zinc-600 transition-colors">{item.data.title}</h3>
              </a>
              <p class="text-zinc-600 leading-relaxed text-lg mb-5">{item.data.summary ?? item.body}</p>
              <a href={newsHref(item.id)} class="inline-flex items-center text-sm font-bold text-zinc-900 hover:gap-2 transition-all">
                Read more <ChevronRight size={16} className="ml-1" />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

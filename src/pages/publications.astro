---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowLeft } from 'lucide-react';

const years = [2025, 2024, 2023];
---

<BaseLayout title="Publications" description="Research contributions in HCI, XR, and AI.">
  <div class="pt-32 pb-24 px-6 min-h-screen bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <a href="/" class="inline-flex items-center text-sm font-medium text-zinc-500 hover:text-zinc-900 transition-colors mb-8 group">
          <ArrowLeft size={16} className="mr-2 group-hover:-translate-x-1 transition-transform" /> Back to Home
        </a>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 mb-6">Publications</h1>
        <p class="text-xl text-zinc-500 max-w-3xl">Research contributions in HCI, XR, and AI.</p>
        <div class="h-1 bg-zinc-900 w-20 mt-8" />
      </div>

      <div class="space-y-12">
        {years.map((year) => (
          <div>
            <h3 class="text-xl font-bold text-zinc-400 mb-8 border-b border-zinc-100 pb-2">{year}</h3>
            <div class="space-y-8">
              {[1, 2].map((pub) => (
                <div class="group">
                  <p class="text-lg font-bold group-hover:text-zinc-600 transition-colors mb-2">
                    Towards Seamless Interaction: A Study on AI-Driven Gesture Recognition in Immersive XR Environments
                  </p>
                  <p class="text-zinc-500 text-sm mb-3">
                    <span class="font-bold text-zinc-900">Kevin Zhao</span>, J. Smith, L. Wang.
                  </p>
                  <p class="text-zinc-400 text-xs uppercase tracking-widest italic">
                    Proceedings of the ACM on Human-Computer Interaction (PACMHCI), {year}
                  </p>
                  <div class="flex gap-4 mt-4">
                    <a href="#" class="text-xs font-bold text-zinc-900 flex items-center gap-1 hover:underline">
                      [PDF]
                    </a>
                    <a href="#" class="text-xs font-bold text-zinc-900 flex items-center gap-1 hover:underline">
                      [DOI]
                    </a>
                    <a href="#" class="text-xs font-bold text-zinc-900 flex items-center gap-1 hover:underline">
                      [Code]
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

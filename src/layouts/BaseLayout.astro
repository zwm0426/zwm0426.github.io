---
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import '../index.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Kevin ZHAO Weiming's Personal Portfolio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Kevin Zhao</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-white text-zinc-900 selection:bg-zinc-900 selection:text-white font-sans">
    <Navbar client:load />
    <main>
      <slot />
    </main>
    <Footer client:load />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
